---
import { getLocale, localePath, t } from '@i18n/ui';

const locale = getLocale(Astro.url);
const erisaleHref = `https://www.erisale.com/?locale=${locale}`;
---

<footer class="site-footer" data-pagefind-ignore>
  <hr class="gleam" />
  <div class="wrap footer-inner ui">
    <p class="footer-note muted">
      {t(locale, 'footer.companion')}
      <a href={erisaleHref} rel="noopener" target="_blank">erisale.com</a>.
    </p>

    <nav aria-label="Footer" class="footer-nav">
      <a href={localePath('/about/', locale)}>{t(locale, 'footer.aboutIntent')}</a>
      <a href={`${localePath('/about/', locale)}#copyright`}>{t(locale, 'footer.copyright')}</a>
      <a href={erisaleHref} rel="noopener" target="_blank">{t(locale, 'footer.officialSource')}</a>
    </nav>

    <p class="footer-license muted">
      {t(locale, 'footer.license')}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    flex-shrink: 0;
    padding-bottom: var(--space-xl);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    font-size: var(--step--1);
    line-height: var(--leading-snug);
  }
  .footer-note {
    max-width: var(--measure);
  }
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
  }
  .footer-nav a {
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--hairline);
  }
  .footer-nav a:hover {
    color: var(--text);
  }
  .footer-license {
    font-size: var(--step--1);
    opacity: 0.85;
  }
</style>
