---
import { isActive } from '@lib/paths';
import { getLocale, localePath, t } from '@i18n/ui';
import ThemeToggle from '@components/ThemeToggle.astro';
import LanguageSwitch from '@components/LanguageSwitch.astro';
import HeaderSearch from '@components/HeaderSearch.astro';

const current = Astro.url.pathname;
const locale = getLocale(Astro.url);
const base = import.meta.env.BASE_URL;

// Content sections (Flashes/Glossary/Themes/Search) are English for now, so they
// link to the English routes regardless of locale; About has a Turkish twin.
const nav = [
  { href: localePath('/flashes/', 'en'), label: t(locale, 'nav.flashes') },
  { href: localePath('/glossary/', 'en'), label: t(locale, 'nav.glossary') },
  { href: localePath('/themes/', 'en'), label: t(locale, 'nav.themes') },
  { href: localePath('/search/', 'en'), label: t(locale, 'nav.search') },
  { href: localePath('/about/', locale), label: t(locale, 'nav.about') },
];
---

<header class="site-header" data-pagefind-ignore>
  <div class="wrap header-inner">
    <a class="brand" href={localePath('/', locale)}>
      <img class="brand-mark" src={`${base}icons/icon.svg`} width="30" height="30" alt="" aria-hidden="true" />
      <span class="brand-text">
        <span class="brand-title">{locale === 'tr' ? 'Lem’alar' : 'The Flashes'}</span>
        <span class="brand-sub ui">{t(locale, 'brand.companion')}</span>
      </span>
    </a>

    <nav aria-label="Primary" class="primary-nav ui">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href, current) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-controls">
      <HeaderSearch />
      <LanguageSwitch />
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--hairline);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    min-height: 4rem;
    padding-block: var(--space-2xs);
  }
  .header-controls {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    text-decoration: none;
    color: var(--text);
    margin-right: auto;
  }
  .brand-mark {
    display: block;
    width: 30px;
    height: 30px;
    border-radius: 7px;
    filter: drop-shadow(0 0 6px var(--glow));
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 600;
  }
  .brand-sub {
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .primary-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .primary-nav a {
    display: inline-block;
    padding: var(--space-3xs) var(--space-2xs);
    color: var(--muted);
    text-decoration: none;
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .primary-nav a:hover,
  .primary-nav a[aria-current='page'] {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 40rem) {
    .header-inner {
      flex-wrap: wrap;
      gap: var(--space-2xs);
    }
    .primary-nav {
      order: 3;
      width: 100%;
    }
    .primary-nav ul {
      justify-content: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
