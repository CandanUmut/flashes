---
export interface Props {
  number: number;
}
const { number } = Astro.props;
---

<button type="button" class="read-toggle ui" data-flash={number} aria-pressed="false">
  <span class="rt-box" aria-hidden="true"></span>
  <span class="rt-label">Mark as read</span>
</button>

<script>
  import { isRead, toggleRead } from '@lib/progress';

  const btn = document.currentScript?.previousElementSibling as HTMLButtonElement | null;
  if (btn) {
    const n = Number(btn.dataset.flash);
    const label = btn.querySelector('.rt-label') as HTMLElement | null;

    const paint = (read: boolean) => {
      btn.setAttribute('aria-pressed', read ? 'true' : 'false');
      btn.classList.toggle('is-read', read);
      if (label) label.textContent = read ? 'Read ✓' : 'Mark as read';
    };

    paint(isRead(n));
    btn.addEventListener('click', () => paint(toggleRead(n)));
  }
</script>

<style>
  .read-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    min-height: 44px;
    padding: var(--space-2xs) var(--space-s);
    background: transparent;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-s);
    color: var(--text);
    font-size: var(--step--1);
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .read-toggle:hover { border-color: var(--accent); }
  .rt-box {
    width: 1.05rem;
    height: 1.05rem;
    border: 1.5px solid var(--muted);
    border-radius: 4px;
    transition: all var(--dur-fast) var(--ease);
  }
  .read-toggle.is-read {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .read-toggle.is-read .rt-box {
    background: var(--accent);
    border-color: var(--accent);
  }
</style>
