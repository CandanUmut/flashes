---
import { withBase } from '@lib/paths';

export interface Props {
  slug: string;
  term: string;
  arabic?: string;
  definition: string;
}
const { slug, term, arabic, definition } = Astro.props;
const href = withBase(`/glossary/${slug}/`);
const popId = `pop-${slug}`;
---

<span class="term-pop" data-term-pop>
  <button
    type="button"
    class="term-trigger"
    aria-expanded="false"
    aria-controls={popId}
  >
    {term}
  </button>
  <span class="term-panel" id={popId} role="dialog" aria-label={`Definition: ${term}`} hidden>
    {arabic && <span class="term-panel-ar arabic" lang="ar" dir="rtl">{arabic}</span>}
    <span class="term-panel-def">{definition}</span>
    <a class="term-panel-link" href={href}>Full definition →</a>
  </span>
</span>

<script>
  // One delegated controller for all term popovers on the page.
  // While open, the panel is *portaled* to <body>. This is deliberate: the page
  // animates `transform` on an ancestor (`main.fade-in`), and any ancestor with
  // a transform/filter makes `position: fixed` resolve against that ancestor
  // instead of the viewport — which made the panel land near the top of the page
  // instead of beside the term. As a direct child of <body> there is no such
  // ancestor, so fixed positioning is reliable.
  let open: HTMLElement | null = null;
  let openTrigger: HTMLElement | null = null;
  let openPanel: HTMLElement | null = null;
  let home: { parent: Node; next: Node | null } | null = null;

  function place() {
    if (!openTrigger || !openPanel) return;
    const margin = 8;
    const panel = openPanel;
    panel.style.position = 'fixed';
    panel.style.left = '0px';
    panel.style.top = '0px';
    const tr = openTrigger.getBoundingClientRect();
    const pw = panel.offsetWidth;
    const ph = panel.offsetHeight;
    let left = Math.min(tr.left, window.innerWidth - pw - margin);
    left = Math.max(margin, left);
    let top = tr.bottom + margin;
    if (top + ph > window.innerHeight - margin && tr.top - margin - ph > margin) {
      top = tr.top - margin - ph;
    }
    panel.style.left = `${Math.round(left)}px`;
    panel.style.top = `${Math.round(top)}px`;
  }

  function close() {
    if (!open) return;
    openTrigger?.setAttribute('aria-expanded', 'false');
    if (openPanel) {
      openPanel.hidden = true;
      openPanel.style.position = '';
      openPanel.style.left = '';
      openPanel.style.top = '';
      // Return the panel to where it came from in the DOM.
      if (home) home.parent.insertBefore(openPanel, home.next);
    }
    open.classList.remove('is-open');
    open = openTrigger = openPanel = home = null;
  }

  function openPop(wrap: HTMLElement) {
    if (open && open !== wrap) close();
    const trigger = wrap.querySelector<HTMLButtonElement>('.term-trigger');
    const panel = wrap.querySelector<HTMLElement>('.term-panel');
    if (!trigger || !panel) return;
    trigger.setAttribute('aria-expanded', 'true');
    panel.hidden = false;
    wrap.classList.add('is-open');
    open = wrap;
    openTrigger = trigger;
    openPanel = panel;
    home = { parent: panel.parentNode as Node, next: panel.nextSibling };
    document.body.appendChild(panel); // portal out of any transformed ancestor
    place();
  }

  // Keep the open panel anchored while the page scrolls or resizes.
  window.addEventListener('scroll', () => { if (open) place(); }, { passive: true });
  window.addEventListener('resize', () => { if (open) place(); });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest<HTMLElement>('.term-trigger');
    if (trigger) {
      const wrap = trigger.closest<HTMLElement>('[data-term-pop]');
      if (!wrap) return;
      if (open === wrap) close();
      else openPop(wrap);
      return;
    }
    // A click anywhere outside the open panel (and not on a trigger) closes it.
    if (open && !target.closest('.term-panel')) close();
  });

  // Interaction is click/tap-only, on purpose. Earlier this component also
  // auto-opened on `focusin` and `mouseenter`, but a <button> fires `focusin`
  // *before* `click`, so the click handler then saw the panel as already open
  // and toggled it straight back closed — which is why tapping a term appeared
  // to do nothing. A <button> emits a real `click` on Enter/Space, so keyboard
  // users still get the toggle; dropping hover also avoids the trigger→panel
  // gap closing the panel before its "Full definition" link can be reached.

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) {
      const trigger = openTrigger;
      close();
      trigger?.focus();
    }
  });
</script>

<style>
  .term-pop {
    position: relative;
    display: inline-block;
  }
  .term-trigger {
    font: inherit;
    color: var(--text);
    background: transparent;
    border: 1px solid var(--hairline);
    border-radius: 100px;
    padding: var(--space-3xs) var(--space-s);
    cursor: pointer;
    border-bottom-style: dotted;
    transition: border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .term-trigger:hover,
  .term-pop.is-open .term-trigger {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* The explicit display below would otherwise override the `hidden`
     attribute's UA `display:none` (equal specificity, author wins), leaving
     every panel visible and overlapping. Keep this rule. */
  .term-panel[hidden] {
    display: none;
  }
  .term-panel {
    position: absolute;
    left: 0;
    top: calc(100% + 8px);
    z-index: 30;
    width: max-content;
    max-width: min(20rem, calc(100vw - 16px));
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding: var(--space-s);
    background: var(--surface-2);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-m);
    box-shadow: var(--shadow);
    font-family: var(--font-ui);
    font-size: var(--step--1);
    line-height: var(--leading-snug);
    text-align: left;
  }
  .term-panel::before {
    /* little gleam accent on the popover edge */
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    border-radius: var(--radius-m) 0 0 var(--radius-m);
    background: var(--accent);
  }
  .term-panel-ar { font-size: 1.3em; color: var(--accent); }
  .term-panel-def { color: var(--text); }
  .term-panel-link { color: var(--accent); text-decoration: none; font-weight: 600; }
  .term-panel-link:hover { text-decoration: underline; }

  @media (max-width: 30rem) {
    .term-panel { left: auto; right: 0; }
  }
</style>
