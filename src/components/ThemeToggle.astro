---
// Theme toggle — a self-contained island. The no-flash script in BaseLayout
// applies the stored theme before paint; this only handles user toggling.
---

<button
  type="button"
  class="theme-toggle ui"
  aria-label="Toggle light and dark theme"
  title="Toggle light / dark"
>
  <span class="icon icon-sun" aria-hidden="true">☼</span>
  <span class="icon icon-moon" aria-hidden="true">☾</span>
</button>

<script>
  const KEY = 'flashes:theme';
  const btn = document.currentScript?.previousElementSibling as HTMLButtonElement | null;

  function current(): 'light' | 'dark' {
    const set = document.documentElement.getAttribute('data-theme');
    if (set === 'light' || set === 'dark') return set;
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  }

  function apply(theme: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', theme);
    try {
      localStorage.setItem(KEY, theme);
    } catch (_) {
      /* ignore */
    }
  }

  btn?.addEventListener('click', () => {
    apply(current() === 'dark' ? 'light' : 'dark');
  });
</script>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    min-width: 44px;
    min-height: 44px;
    background: transparent;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-s);
    color: var(--accent);
    cursor: pointer;
    font-size: 1.1rem;
    transition: border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent-strong);
  }
  .icon {
    grid-area: 1 / 1;
    line-height: 1;
  }
  /* Show moon in dark mode, sun in light mode */
  :global(:root[data-theme='dark']) .icon-sun,
  :global(:root:not([data-theme])) .icon-sun {
    display: none;
  }
  :global(:root[data-theme='light']) .icon-moon {
    display: none;
  }
  @media (prefers-color-scheme: light) {
    :global(:root:not([data-theme])) .icon-sun {
      display: block;
    }
    :global(:root:not([data-theme])) .icon-moon {
      display: none;
    }
  }
</style>
