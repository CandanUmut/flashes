---
import '@styles/fonts.css';
import '@styles/tokens.css';
import '@styles/global.css';
import '@styles/print.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { localeAlternates } from '@i18n/ui';

export interface Props {
  title: string;
  description?: string;
  /** Page language for <html lang>. Defaults to English. */
  lang?: 'en' | 'tr';
  /** Set false on pages that should not be indexed by Pagefind (e.g. search page). */
  indexable?: boolean;
}

const {
  title,
  description = 'A companion and study guide for Lem’alar (The Flashes) by Bediüzzaman Said Nursî — outlines, summaries, glossary and search around the original text. Not the book itself.',
  lang = 'en',
  indexable = true,
} = Astro.props;

const siteName = 'The Flashes — A Companion';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const base = import.meta.env.BASE_URL;
const ogImage = Astro.site
  ? new URL(`${base}icons/icon-512.png`, Astro.site).href
  : `${base}icons/icon-512.png`;

// Canonical + hreflang. Astro.site is set in astro.config.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const alternates = Astro.site
  ? localeAlternates(Astro.url).map((a) => ({
      hreflang: a.hreflang,
      href: new URL(a.path, Astro.site).href,
    }))
  : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`${base}icons/icon-192.png`} />
    <title>{fullTitle}</title>

    {/* ---- Progressive Web App ---- */}
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <meta name="theme-color" content="#15132a" />
    <link rel="apple-touch-icon" href={`${base}icons/apple-touch-icon.png`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />
    <meta name="apple-mobile-web-app-title" content="Flashes" />
    <meta name="application-name" content="Flashes" />
    <meta property="og:image" content={ogImage} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="color-scheme" content="dark light" />

    {/* No-flash theme: set data-theme before first paint from stored choice. */}
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('flashes:theme');
          if (stored === 'light' || stored === 'dark') {
            document.documentElement.setAttribute('data-theme', stored);
          }
        } catch (_) {
          /* localStorage unavailable; fall back to prefers-color-scheme */
        }
      })();
    </script>

    {/* Register the service worker so the app is installable and works offline. */}
    <script is:inline define:vars={{ swUrl: `${base}sw.js`, swScope: base }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swUrl, { scope: swScope }).catch(() => {});
        });
      }
    </script>
  </head>
  <body data-indexable={indexable ? 'true' : 'false'}>
    <a class="skip-link ui" href="#main">Skip to content</a>
    <Header />
    <main id="main" class="fade-in">
      <slot />
    </main>
    <Footer />
  </body>
</html>
