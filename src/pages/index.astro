---
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@lib/paths';

const siteName = 'The Flashes — A Companion';

const entries = [
  {
    href: withBase('/flashes/'),
    title: 'Browse the Flashes',
    desc: 'All 33 Flashes — outlines, essences and themes.',
    mark: '✦',
  },
  {
    href: withBase('/glossary/'),
    title: 'Glossary',
    desc: 'Plain definitions of recurring Risale terms.',
    mark: '◈',
  },
  {
    href: withBase('/search/'),
    title: 'Search',
    desc: 'Find a concept across the companion notes.',
    mark: '⌕',
  },
  {
    href: withBase('/about/'),
    title: 'Continue reading',
    desc: 'Pick up where you left off. (Coming soon.)',
    mark: '↳',
  },
];
---

<BaseLayout title={siteName}>
  <section class="wrap hero glow-title">
    <p class="eyebrow">Lem’alar · The Flashes · Risale-i Nur</p>
    <h1>A companion to <em>The Flashes</em></h1>
    <p class="lede prose">
      A map, outline and glossary for <em>Lem’alar</em> (“The Flashes”) by
      Bediüzzaman Said Nursî. This site is <strong>not the book</strong> and does
      not reproduce its text or any translation — it is an independent study aid
      that helps you navigate, understand and remember the work, then sends you to
      the official source to read it.
    </p>
    <p class="prose">
      <a class="source-link" href="https://www.erisale.com/?locale=en" rel="noopener" target="_blank">
        Read the full text on erisale.com&nbsp;→
      </a>
    </p>
  </section>

  <hr class="gleam" />

  <section class="wrap">
    <ul class="entry-grid">
      {
        entries.map((e) => (
          <li>
            <a class="entry-card" href={e.href}>
              <span class="entry-mark" aria-hidden="true">{e.mark}</span>
              <span class="entry-title">{e.title}</span>
              <span class="entry-desc muted">{e.desc}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-xl) var(--space-l);
    text-align: center;
  }
  .hero h1 {
    font-size: var(--step-4);
    margin-bottom: var(--space-m);
  }
  .lede {
    font-size: var(--step-1);
    color: var(--text);
  }
  .source-link {
    font-family: var(--font-ui);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }
  .entry-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-m);
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .entry-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    height: 100%;
    padding: var(--space-m);
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-l);
    text-decoration: none;
    color: var(--text);
    box-shadow: var(--shadow);
    transition: transform var(--dur-med) var(--ease), border-color var(--dur-med) var(--ease);
  }
  @media (prefers-reduced-motion: no-preference) {
    .entry-card:hover {
      transform: translateY(-3px);
      border-color: var(--accent);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .entry-card:hover { border-color: var(--accent); }
  }
  .entry-mark {
    font-size: 1.6rem;
    color: var(--accent);
    filter: drop-shadow(0 0 8px var(--glow));
  }
  .entry-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 600;
  }
  .entry-desc {
    font-family: var(--font-ui);
    font-size: var(--step--1);
  }
</style>
