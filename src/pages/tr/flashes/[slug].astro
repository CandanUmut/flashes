---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@lib/paths';

export async function getStaticPaths() {
  const flashes = (await getCollection('flashes')).sort(
    (a, b) => a.data.number - b.data.number
  );
  return flashes.map((flash, i) => ({
    params: { slug: flash.id },
    props: {
      flash,
      prev: i > 0 ? flashes[i - 1] : null,
      next: i < flashes.length - 1 ? flashes[i + 1] : null,
    },
  }));
}

const { flash, prev, next } = Astro.props;
const d = flash.data;
const { Content } = await render(flash);

const themes = await getCollection('themes');
const themeNames: Record<string, string> = Object.fromEntries(
  themes.map((t) => [t.id, t.data.name])
);

const title = d.titleTr ?? d.title;
const essence = d.essenceTr ?? d.essence;
const sourceUrl = d.source.erisaleUrlTr ?? d.source.erisaleUrlEn;
const contextNote = d.context?.noteTr ?? d.context?.note;
const summaryParas = d.summaryTr ? d.summaryTr.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean) : null;
const prevTitle = (p: typeof prev) => (p ? p.data.titleTr ?? p.data.title : '');
---

<BaseLayout title={title} description={essence} lang="tr">
  <article class="wrap flash" data-flash-number={d.number}>
    <header class="flash-head glow-title">
      <p class="eyebrow">
        <a href={withBase('/tr/flashes/')}>Lem'alar</a> · No. {d.number}
      </p>
      <h1>{title}</h1>
      {d.titleTr && d.title && (
        <p class="title-alt ui muted" lang="en">{d.title}</p>
      )}
      <p class="essence">{essence}</p>

      {d.special?.fifteenDayReminder && (
        <p class="fifteen-day ui"><span aria-hidden="true">✦</span> Nursî bu Lem'a'nın en az on beş günde bir okunmasını istemiştir.</p>
      )}

      <div class="head-meta ui">
        {d.readingTimeMin && <span class="meta-item">~{d.readingTimeMin} dk okuma (asıl metin)</span>}
        {d.context?.writtenWhere && <span class="meta-item">{d.context.writtenWhere}</span>}
      </div>

      <div class="head-actions">
        <a class="source-btn ui" href={sourceUrl} rel="noopener" target="_blank">
          erisale.com'da oku →
        </a>
      </div>
      <p class="companion-cue ui">Rehber notları — Lem'a'nın bir haritası, Nursî'nin kendi sözleri değil.</p>

      {contextNote && <p class="context-note ui muted">{contextNote}</p>}
    </header>

    {/* Opening verses (Turkish meaning) */}
    {d.openingVerses && d.openingVerses.length > 0 && (
      <section class="verses" aria-label="Açılış âyetleri">
        <h2 class="section-head">Açılış âyetleri</h2>
        <ol class="verse-list">
          {d.openingVerses.map((v) => (
            <li class="verse">
              <p class="arabic" lang="ar" dir="rtl">{v.arabic}</p>
              <p class="verse-tr">“{v.translationTr ?? v.translationEn}” <span class="verse-ref ui">{v.reference}</span></p>
            </li>
          ))}
        </ol>
      </section>
    )}

    {/* Outline */}
    {d.outline.length > 0 && (
      <section class="outline" aria-label="Yapı haritası">
        <h2 class="section-head">Plan</h2>
        <p class="section-sub ui muted">Lem'a'nın yapısal haritamız.</p>
        <ol class="outline-list">
          {d.outline.map((node) => (
            <li class="outline-node" id={node.id}>
              <h3 class="outline-heading">{node.headingTr ?? node.heading}</h3>
              {(node.noteTr ?? node.note) && <p class="outline-note">{node.noteTr ?? node.note}</p>}
            </li>
          ))}
        </ol>
      </section>
    )}

    <hr class="gleam" />

    {/* Summary (Turkish, or English fallback) */}
    <section class="summary" aria-label="Rehber özeti">
      <h2 class="section-head">Rehber özeti</h2>
      {summaryParas ? (
        <div class="prose summary-body">
          {summaryParas.map((p) => <p>{p}</p>)}
        </div>
      ) : (
        <>
          <p class="fallback-note ui muted">Bu Lem'a'nın Türkçe rehber metni henüz hazırlanıyor; aşağıda İngilizce özet gösteriliyor.</p>
          <div class="prose summary-body"><Content /></div>
        </>
      )}
    </section>

    {/* Key concepts → glossary */}
    {d.keyConcepts.length > 0 && (
      <section class="concepts" aria-label="Anahtar kavramlar">
        <h2 class="section-head">Anahtar kavramlar</h2>
        <div class="concept-list">
          {d.keyConcepts.map((slug) => (
            <a class="chip" href={withBase(`/glossary/${slug}/`)}>{slug}</a>
          ))}
        </div>
      </section>
    )}

    {/* Cross references */}
    {d.crossRefs && d.crossRefs.length > 0 && (
      <section class="crossrefs ui" aria-label="İlgili bölümler">
        <h2 class="section-head">Başka yerlerde</h2>
        <ul>
          {d.crossRefs.map((c) => (
            <li>
              <strong>{c.workTr ?? c.work}</strong> — {c.refTr ?? c.ref}
              {(c.noteTr ?? c.note) && <span class="muted"> · {c.noteTr ?? c.note}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* Themes */}
    {d.themes.length > 0 && (
      <section class="flash-themes ui" aria-label="Temalar">
        {d.themes.map((t) => (
          <a class="chip" href={withBase(`/themes/${t}/`)}>{themeNames[t] ?? t}</a>
        ))}
      </section>
    )}

    <hr class="gleam" />

    <footer class="flash-foot ui">
      <a class="foot-source" href={sourceUrl} rel="noopener" target="_blank">
        Bu Lem'a'yı erisale.com'da oku →
      </a>
      <nav class="flash-nav" aria-label="Lem'a gezinmesi">
        {prev ? (
          <a class="nav-prev" href={withBase(`/tr/flashes/${prev.id}/`)}>
            <span class="nav-dir">← Önceki</span>
            <span class="nav-title">{prevTitle(prev)}</span>
          </a>
        ) : <span />}
        {next ? (
          <a class="nav-next" href={withBase(`/tr/flashes/${next.id}/`)}>
            <span class="nav-dir">Sonraki →</span>
            <span class="nav-title">{prevTitle(next)}</span>
          </a>
        ) : <span />}
      </nav>
    </footer>
  </article>
</BaseLayout>

<style>
  .flash { max-width: var(--measure); }
  .flash-head { padding-block: var(--space-l) var(--space-s); }
  .eyebrow a { color: var(--muted); text-decoration: none; }
  .eyebrow a:hover { color: var(--accent); }
  .title-alt { margin: calc(-1 * var(--space-2xs)) 0 var(--space-s); font-size: var(--step-0); }
  .essence { font-size: var(--step-1); color: var(--text); margin-top: var(--space-2xs); }
  .fifteen-day {
    display: flex; gap: var(--space-2xs); align-items: baseline;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid var(--hairline); border-radius: var(--radius-m);
    padding: var(--space-2xs) var(--space-s); font-size: var(--step--1); color: var(--text);
  }
  .fifteen-day span { color: var(--accent); }
  .head-meta { display: flex; flex-wrap: wrap; gap: var(--space-2xs) var(--space-s); font-size: var(--step--1); color: var(--muted); margin-block: var(--space-s); }
  .head-actions { display: flex; flex-wrap: wrap; gap: var(--space-2xs); align-items: center; margin-bottom: var(--space-s); }
  .source-btn {
    display: inline-flex; align-items: center; min-height: 44px;
    padding: var(--space-2xs) var(--space-m); background: var(--accent); color: var(--bg);
    font-weight: 600; font-size: var(--step--1); text-decoration: none; border-radius: var(--radius-s);
    transition: background var(--dur-fast) var(--ease);
  }
  .source-btn:hover { background: var(--accent-strong); color: var(--bg); }
  .companion-cue { margin: var(--space-2xs) 0 0; font-size: var(--step--1); color: var(--muted); }
  .context-note { font-size: var(--step--1); margin-top: var(--space-2xs); }
  .fallback-note { margin-bottom: var(--space-s); }

  .section-head { font-size: var(--step-1); margin-bottom: var(--space-3xs); }
  .section-sub { font-size: var(--step--1); margin-top: 0; }

  .verses { margin-block: var(--space-l); }
  .verse-list { list-style: none; margin: var(--space-s) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-m); }
  .arabic { font-family: var(--font-arabic, serif); font-size: var(--step-2); line-height: 2; margin: 0; }
  .verse-tr { margin: var(--space-2xs) 0 0; }
  .verse-ref { color: var(--muted); font-size: var(--step--1); margin-left: var(--space-2xs); }

  .outline-list { list-style: none; margin: var(--space-s) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-2xs); }
  .outline-node { padding: var(--space-s) var(--space-m); background: var(--surface); border: 1px solid var(--hairline); border-left: 3px solid var(--accent); border-radius: var(--radius-m); }
  .outline-heading { font-family: var(--font-body); font-size: var(--step-0); font-weight: 600; margin: 0; }
  .outline-note { margin: var(--space-3xs) 0 0; color: var(--muted); font-size: var(--step--1); line-height: var(--leading-snug); }

  .concept-list, .flash-themes { display: flex; flex-wrap: wrap; gap: var(--space-2xs); margin-top: var(--space-s); }
  .flash-themes { margin-top: var(--space-l); }
  .chip { padding: var(--space-3xs) var(--space-s); border: 1px solid var(--hairline); border-radius: 100px; color: var(--muted); text-decoration: none; font-size: var(--step--1); }
  .chip:hover { color: var(--accent); border-color: var(--accent); }

  .crossrefs ul { list-style: none; padding: 0; margin: var(--space-s) 0 0; }
  .crossrefs li { margin-bottom: var(--space-2xs); font-size: var(--step--1); }

  .flash-foot { display: flex; flex-direction: column; gap: var(--space-l); }
  .foot-source { align-self: flex-start; color: var(--accent); font-size: var(--step--1); text-decoration: none; border-bottom: 1px solid var(--accent); }
  .flash-nav { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-m); }
  .flash-nav a { display: flex; flex-direction: column; gap: 0.1rem; text-decoration: none; color: var(--text); padding: var(--space-s); border: 1px solid var(--hairline); border-radius: var(--radius-m); }
  .flash-nav a:hover { border-color: var(--accent); }
  .nav-next { text-align: right; }
  .nav-dir { font-size: var(--step--1); color: var(--accent); }
  .nav-title { font-size: var(--step--1); color: var(--muted); }
  @media (max-width: 34rem) { .flash-nav { grid-template-columns: 1fr; } .nav-next { text-align: left; } }
</style>
