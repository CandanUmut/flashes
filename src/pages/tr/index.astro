---
import BaseLayout from '@layouts/BaseLayout.astro';
import { localePath } from '@i18n/ui';

const entries = [
  {
    href: localePath('/flashes/', 'tr'),
    title: 'Lem’aları gez',
    desc: '33 Lem’a — özetler, başlıklar ve temalar.',
    mark: '✦',
  },
  {
    href: localePath('/glossary/', 'en'),
    title: 'Sözlük',
    desc: 'Sık geçen Risale terimlerinin sade açıklamaları.',
    mark: '◈',
  },
  {
    href: localePath('/search/', 'en'),
    title: 'Ara',
    desc: 'Rehber notları içinde bir kavram bulun.',
    mark: '⌕',
  },
  {
    href: localePath('/about/', 'tr'),
    title: 'Hakkında',
    desc: 'Niyet, sadakat ilkeleri ve telif notu.',
    mark: '↳',
  },
];
---

<BaseLayout
  lang="tr"
  title="Lem’alar — Bir Rehber"
  description="Bediüzzaman Said Nursî’nin Lem’alar eseri için bağımsız bir rehber: özetler, başlıklar, sözlük ve arama. Kitabın kendisi değildir."
>
  <section class="wrap hero glow-title">
    <p class="eyebrow">Lem’alar · Risale-i Nur</p>
    <h1><em>Lem’alar</em>’a bir rehber</h1>
    <p class="lede prose">
      Bediüzzaman Said Nursî’nin <em>Lem’alar</em> eseri için bir harita, başlık
      dökümü ve sözlük. Bu site <strong>kitabın kendisi değildir</strong> ve
      metni ya da herhangi bir tercümesini çoğaltmaz — eseri anlamanıza,
      içinde gezinmenize ve hatırlamanıza yardımcı olan bağımsız bir çalışma
      aracıdır; okumak için sizi resmî kaynağa yönlendirir.
    </p>
    <p class="prose">
      <a class="source-link" href="https://www.erisale.com/?locale=tr" rel="noopener" target="_blank">
        Tam metni erisale.com’da okuyun&nbsp;→
      </a>
    </p>
  </section>

  <hr class="gleam" />

  <section class="wrap">
    <p class="tr-note ui muted">
      Not: Rehber içeriğinin <strong>İngilizcesi tamamlanmıştır</strong>;
      Türkçe rehber içeriği hazırlanmaktadır. Aşağıdaki bölümler şimdilik
      İngilizce rehber notlarına bağlanır.
    </p>
    <ul class="entry-grid">
      {
        entries.map((e) => (
          <li>
            <a class="entry-card" href={e.href}>
              <span class="entry-mark" aria-hidden="true">{e.mark}</span>
              <span class="entry-title">{e.title}</span>
              <span class="entry-desc muted">{e.desc}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero { padding-block: var(--space-xl) var(--space-l); text-align: center; }
  .hero h1 { font-size: var(--step-4); margin-bottom: var(--space-m); }
  .lede { font-size: var(--step-1); color: var(--text); }
  .source-link {
    font-family: var(--font-ui);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }
  .tr-note {
    max-width: var(--measure);
    margin: 0 auto var(--space-m);
    text-align: center;
    font-size: var(--step--1);
  }
  .entry-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-m);
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .entry-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    height: 100%;
    padding: var(--space-m);
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-l);
    text-decoration: none;
    color: var(--text);
    box-shadow: var(--shadow);
    transition: transform var(--dur-med) var(--ease), border-color var(--dur-med) var(--ease);
  }
  @media (prefers-reduced-motion: no-preference) {
    .entry-card:hover { transform: translateY(-3px); border-color: var(--accent); }
  }
  @media (prefers-reduced-motion: reduce) {
    .entry-card:hover { border-color: var(--accent); }
  }
  .entry-mark { font-size: 1.6rem; color: var(--accent); filter: drop-shadow(0 0 8px var(--glow)); }
  .entry-title { font-family: var(--font-display); font-size: var(--step-1); font-weight: 600; }
  .entry-desc { font-family: var(--font-ui); font-size: var(--step--1); }
</style>
